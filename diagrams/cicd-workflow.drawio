        <mxCell id="ca2" style="strokeWidth=1;strokeColor=#6c8ebf;" edge="1" source="tfplan" target="ciresult" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Arrow: PR triggers CI -->
        <mxCell id="a4" value="triggers" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=9;" edge="1" source="pr" target="cibox" parent="1">
