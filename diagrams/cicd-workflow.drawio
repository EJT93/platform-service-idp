          <mxGeometry x="40" y="180" width="900" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="cilabel" value="CI Pipeline (ci.yml) — Triggered on: pull_request → main" style="text;html=1;fontSize=13;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="185" width="500" height="20" as="geometry"/>
        </mxCell>

        <!-- CI Jobs -->
        <mxCell id="lint" value="python-lint&#xa;ruff check" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#6c8ebf;" vertex="1" parent="1">
