        </mxCell>
        <mxCell id="test" value="python-test&#xa;pytest -v" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="200" y="220" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="tfval" value="terraform-validate&#xa;init → validate → fmt" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="tfplan" value="terraform-plan&#xa;OIDC auth → plan" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="590" y="220" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ciresult" value="✓ All checks&#xa;pass on PR" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="220" width="110" height="50" as="geometry"/>
