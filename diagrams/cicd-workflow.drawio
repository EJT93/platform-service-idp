        <mxCell id="d2" value="2. OIDC Auth&#xa;→ AWS STS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="180" y="490" width="100" height="50" as="geometry"/>
        </mxCell>
