        <!-- Security note -->
        <mxCell id="secnote" value="Security: No static AWS credentials.&#xa;GitHub OIDC → AssumeRoleWithWebIdentity → Temporary creds (15min TTL).&#xa;Role trust scoped to repo:EJT93/platform-service-idp:*" style="shape=note;whiteSpace=wrap;html=1;fontSize=9;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
