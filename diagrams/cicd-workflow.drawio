        <mxCell id="deploylabel" value="Deploy Pipeline (deploy.yml) — Triggered on: push → main" style="text;html=1;fontSize=13;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="50" y="455" width="500" height="20" as="geometry"/>
