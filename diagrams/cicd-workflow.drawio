        </mxCell>
        <mxCell id="d5" value="5. terraform apply&#xa;-var-file dev.tfvars&#xa;-auto-approve" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="610" y="490" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="d6" value="✓ Deployed" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="490" width="100" height="50" as="geometry"/>
